COMPOSE_PROJECT_NAME=idea-maker
POSTGRES_DB=idea_maker
POSTGRES_USER=idea_maker
POSTGRES_PASSWORD=idea_maker_dev_password
DATABASE_URL=postgresql://idea_maker:idea_maker_dev_password@db:5432/idea_maker
API_PORT=8000
WEB_PORT=5173
POSTGRES_PORT=55432
LOCAL_GEMMA_BASE_URL=http://host.docker.internal:8089
LOCAL_GEMMA_MODEL=gemma4
LOCAL_GEMMA_TIMEOUT_SECONDS=4
LOCAL_GEMMA_CONTEXT_TIMEOUT_SECONDS=4
LOCAL_GEMMA_QUICK_EXAMPLES_TIMEOUT_SECONDS=180
LOCAL_GEMMA_RECOMMENDATIONS_TIMEOUT_SECONDS=180
